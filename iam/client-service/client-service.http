Content-Type: application/json

{
  "clientName": "ema-2",
  "clientSecret": "my-secret",
  "clientAuthenticationMethods": [
    "CLIENT_SECRET_BASIC"
  ],
  "authorizationGrantTypes": [
    "AUTHORIZATION_CODE"
  ],
  "scopes": [
    "default.read"
  ],
  "redirectUris": [
    "http://localhost:2001/swagger-ui/index.html?continue#/Client/updateClient"
  ],
  "postLogoutRedirectUris": [
    "http://localhost:2001/swagger-ui/index.html?continue#/Client/updateClient"
  ],
  "clientSecretExpiresAt": "2023-12-29T09:22:41.970Z"
}

