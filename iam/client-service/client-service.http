###
# Create Client
POST http://localhost:2001/v1/api/client/create
accept: application/json
Content-Type: application/json

{
  "clientName": "ema-2",
  "clientSecret": "my-secret",
  "scopes": [
    "admin.read"
  ],
  "clientAuthenticationMethods": [
    "CLIENT_SECRET_BASIC"
  ],
  "authorizationGrantTypes": [
    "AUTHORIZATION_CODE"
  ],
  "redirectUris": [
    "http://localhost:2001/swagger-ui/index.html?continue#/Client/createClient"
  ],
  "postLogoutRedirectUris": [
    "http://localhost:2001/swagger-ui/index.html?continue#/Client/createClient",
    "http://localhost:2001/swagger-ui/index.html?continue#/Client/createClient"
  ],
  "clientSecretExpiresAt": "2023-12-29T08:11:46.715Z"
}

